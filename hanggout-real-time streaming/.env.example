# Firebase Configuration
# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_KEY_PATH=./config/haang-out-61e3d-firebase-adminsdk-fbsvc-b6f4f6e9eb.json

# Snowflake Configuration
# Get these credentials from your Snowflake account
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=your_account_id.region.cloud
SNOWFLAKE_WAREHOUSE=your_warehouse_name
SNOWFLAKE_DATABASE=your_database_name
SNOWFLAKE_SCHEMA=your_schema_name

# Kafka Configuration
# For local development with Docker Compose
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=hanggout-topic
